# =============================================================================
# 阿里云 DashScope API Key（三处共用，只需填一次）
#   - 大模型对话（LLM）
#   - 语音合成（TTS，见 tts_config.yaml）
#   - 语音识别（ASR，见 asr_config.yaml）
#
# 程序读取顺序：若设置了 DASHSCOPE_API_KEY 则用它；否则自动使用下面的 LLM_API_KEY。
# 一般只填 LLM_API_KEY 即可，无需再写 DASHSCOPE_API_KEY。
# =============================================================================
LLM_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash

# 可选：仅当 TTS/ASR 要用与 LLM 不同的 Key 时再填写（多数情况留空）
# DASHSCOPE_API_KEY=

# 数据库（默认 SQLite，无需修改）
DATABASE_URL=sqlite:///./interview_agent.db
